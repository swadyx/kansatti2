Tonttulib tLib;

// ===================== USER SETTINGS =====================
static constexpr uint32_t TELEMETRY_PERIOD_MS = 100;
static constexpr float    THRUST_STEP         = 0.02f;
static constexpr float    THRUST_MIN          = 0.00f;
static constexpr float    THRUST_MAX          = 0.90f;

static float baseThrust  = 0.45f;
static bool  motorsArmed = false;

// ===================== CONTROL SETTINGS =====================
static constexpr uint32_t RATE_PERIOD_US      = 1000;   // 1000 Hz
static constexpr uint32_t ANGLE_PERIOD_US     = 4000;   // 250 Hz
static constexpr float    RATE_DT             = RATE_PERIOD_US  * 1e-6f;
static constexpr float    ANGLE_DT            = ANGLE_PERIOD_US * 1e-6f;
static constexpr float    ANGLE_FUSE_ALPHA    = 0.985f;

static constexpr float ANGLE_I_MAX        = 2;
static constexpr float MAX_ANGLE_RATE_DPS = 400.0f;

// Rate loop — low inertia means less P needed
static float RATE_KP_ROLL       = 0.0008f;
static float RATE_KP_PITCH      = 0.0008f;
static float RATE_KP_YAW        = 0.0012f;

// I — keep low until P is settled
static float RATE_KI_ROLL       = 0.0f;
static float RATE_KI_PITCH      = 0.0f;
static float RATE_KI_YAW        = 0.0f;

// D — start very small, add only after P is tuned
static float RATE_KD_ROLL       = 0.000003f;
static float RATE_KD_PITCH      = 0.000003f;
static float RATE_KD_YAW        = 0.0f;

// Angle loop — these are fine as-is
static float ANGLE_KP_ROLL      = 3.0f;
static float ANGLE_KP_PITCH     = 3.0f;
static float ANGLE_KI_ROLL      = 0.0f;  // zero until rate loop is tuned
static float ANGLE_KI_PITCH     = 0.0f;

static constexpr float RATE_I_MAX = 0.15f;

static constexpr float GYRO_LPF_ALPHA = 0.2f;

static constexpr float ROLL_OUT_MAX   = 0.3f;
static constexpr float PITCH_OUT_MAX  = 0.3f;
static constexpr float YAW_OUT_MAX    = 0.12f;

static constexpr float ROLL_RATE_SIGN  = +1.0f;
static constexpr float PITCH_RATE_SIGN = +1.0f;
static constexpr float YAW_RATE_SIGN   = +1.0f;

static constexpr float ACC_ROLL_SIGN   = +1.0f;
static constexpr float ACC_PITCH_SIGN  = +1.0f;

static inline float clamp_f(float x, float lo, float hi) {
    return x < lo ? lo : x > hi ? hi : x;
}

// ===================== Motors =====================
static uint16_t m1_us=1000, m2_us=1000, m3_us=1000, m4_us=1000;
static void motorsSetAll(uint16_t us) {
    tLib.motors.set(1,us); tLib.motors.set(2,us);
    tLib.motors.set(3,us); tLib.motors.set(4,us);
}

// ===================== IMU =====================
static float ax_g=0, ay_g=0, az_g=0;
static float gx_dps=0, gy_dps=0, gz_dps=0;
static double gyroBiasX=0, gyroBiasY=0, gyroBiasZ=0;
static double accelBiasX=0, accelBiasY=0, accelBiasZ=0;
static float  rollEst=0, pitchEst=0, yawEst=0;
static bool   angleInit = false;
static uint32_t lastImuUs = 0;
static constexpr uint32_t IMU_PERIOD_US = 5000;

static void calibrateGyro() {
  float ogx = 0, ogy = 0, ogz = 0;
  float gx, gy, gz;
  gyroBiasX = gyroBiasY = gyroBiasZ = 0;

  const int samples = 3000;
  double sumX = 0, sumY = 0, sumZ = 0;

  for (int i = 0; i < samples; i++) {
    tLib.imu.readGyro(gx, gy, gz);

    const float alphaA = 0.2f;
    ogx += alphaA * (gx - ogx);
    ogy += alphaA * (gy - ogy);
    ogz += alphaA * (gz - ogz);

    sumX += ogx;
    sumY += ogy;
    sumZ += ogz;

    delayMicroseconds(500);
  }

  gyroBiasX = sumX / samples;
  gyroBiasY = sumY / samples;
  gyroBiasZ = sumZ / samples;
}

