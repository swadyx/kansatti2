static void sensorStep(uint32_t nowUs) {
  if ((int32_t)(nowUs - lastImuUs) < (int32_t)IMU_PERIOD_US) return;

  const uint32_t prevUs = lastImuUs;
  lastImuUs = nowUs;

  float dt = (nowUs - prevUs) * 1e-6f;
  if (dt <= 0.0f || dt > 0.1f) dt = 0.005f;

  float ax, ay, az, gx, gy, gz;
  tLib.imu.readAll(ax, ay, az, gx, gy, gz);

  ax_g = ax - (float)accelBiasX;
  ay_g = ay - (float)accelBiasY;
  az_g = az - (float)accelBiasZ;

  float gyroMag = sqrtf(gx*gx + gy*gy + gz*gz);
  if (gyroMag < 0.5f && fabsf(ax_g) < 0.15f && fabsf(ay_g) < 0.15f && fabsf(az_g - 1.0f) < 0.20f) {
    const float biasAlpha = 0.03f;
    gyroBiasX += biasAlpha * ((double)gx - gyroBiasX);
    gyroBiasY += biasAlpha * ((double)gy - gyroBiasY);
    gyroBiasZ += biasAlpha * ((double)gz - gyroBiasZ);
  }

  gx_dps = gx - (float)gyroBiasX;
  gy_dps = gy - (float)gyroBiasY;
  gz_dps = gz - (float)gyroBiasZ;

  float accRoll_deg  = ACC_ROLL_SIGN  * atan2f(ay_g, az_g) * 57.2957795f;
  float accPitch_deg = ACC_PITCH_SIGN * atan2f(-ax_g, sqrtf(ay_g*ay_g + az_g*az_g)) * 57.2957795f;

  if (!angleInit) {
    rollEst  = accRoll_deg;
    pitchEst = accPitch_deg;
    angleInit = true;
  } else {
    rollEst  = ANGLE_FUSE_ALPHA * (rollEst  + gx_dps * dt)
             + (1.0f - ANGLE_FUSE_ALPHA) * accRoll_deg;
    pitchEst = ANGLE_FUSE_ALPHA * (pitchEst + gy_dps * dt)
             + (1.0f - ANGLE_FUSE_ALPHA) * accPitch_deg;
  }

  yawEst += gz_dps * dt;
}

// ===================== PID state =====================
static float angleI_roll=0, angleI_pitch=0;
static float rateI_roll=0, rateI_pitch=0, rateI_yaw=0;
static float rollSp=0, pitchSp=0;
static float rollRate_prev=0, pitchRate_prev=0, yawRate_prev=0;

static void resetPIDState() {
    angleI_roll = angleI_pitch = 0.0f;
    rateI_roll = rateI_pitch = rateI_yaw = 0.0f;
    rollSp = pitchSp = 0.0f;
    rollRate_prev = pitchRate_prev = yawRate_prev = 0.0f;
}

static void sendPIDConfig() {
    PIDConfig cfg;
    cfg.angle_kp_roll  = ANGLE_KP_ROLL;   cfg.angle_kp_pitch = ANGLE_KP_PITCH;
    cfg.angle_ki_roll  = ANGLE_KI_ROLL;   cfg.angle_ki_pitch = ANGLE_KI_PITCH;
    cfg.rate_kp_roll   = RATE_KP_ROLL;    cfg.rate_kp_pitch  = RATE_KP_PITCH;  cfg.rate_kp_yaw  = RATE_KP_YAW;
    cfg.rate_ki_roll   = RATE_KI_ROLL;    cfg.rate_ki_pitch  = RATE_KI_PITCH;  cfg.rate_ki_yaw  = RATE_KI_YAW;
    cfg.rate_kd_roll   = RATE_KD_ROLL;    cfg.rate_kd_pitch  = RATE_KD_PITCH;  cfg.rate_kd_yaw  = RATE_KD_YAW;
    sendPacket(Serial1, cfg);
    Serial.println("[FC] PIDConfig sent");
}

static void applyPIDCommand(const PIDCommand &pc) {
    switch (pc.gain_id) {
        case 0:  ANGLE_KP_ROLL  = pc.value; break;
        case 1:  ANGLE_KP_PITCH = pc.value; break;
        case 2:  ANGLE_KI_ROLL  = pc.value; break;
        case 3:  ANGLE_KI_PITCH = pc.value; break;
        case 4:  RATE_KP_ROLL   = pc.value; break;
        case 5:  RATE_KP_PITCH  = pc.value; break;
        case 6:  RATE_KP_YAW    = pc.value; break;
        case 7:  RATE_KI_ROLL   = pc.value; break;
        case 8:  RATE_KI_PITCH  = pc.value; break;
        case 9:  RATE_KI_YAW    = pc.value; break;
        case 10: RATE_KD_ROLL   = pc.value; break;
        case 11: RATE_KD_PITCH  = pc.value; break;
        case 12: RATE_KD_YAW    = pc.value; break;
        case 0xFE: sendPIDConfig(); return;
        case 0xFF: resetPIDState(); Serial.println("[FC] Integrators reset"); return;
        default: Serial.printf("[FC] Unknown gain_id %d\n", pc.gain_id); return;
    }
    Serial.printf("[FC] Gain[%d] = %.6f\n", pc.gain_id, pc.value);
    sendPIDConfig();
}

// ===================== Commands =====================
static uint8_t stringToCmd(const char* s) {
    if (strcmp(s,"arm")     == 0) return 12;
    if (strcmp(s,"disarm")  == 0) return 13;
    if (strcmp(s,"thrust+") == 0) return 10;
    if (strcmp(s,"thrust-") == 0) return 11;
    if (strcmp(s,"ledon")   == 0) return 1;
    if (strcmp(s,"ledoff")  == 0) return 2;
    if (strcmp(s,"ping")    == 0) return 0xFF;
    return 0;
}

static void applyCommand(uint8_t cmd) {
    switch (cmd) {
        case 1:  tLib.led.on();        Serial.println("[FC] LED on");     break;
        case 2:  tLib.led.off();       Serial.println("[FC] LED off");    break;
        case 3:  tLib.led.blinkFast(); Serial.println("[FC] blink fast"); break;
        case 4:  tLib.led.blinkSlow(); Serial.println("[FC] blink slow"); break;
        case 10:
            baseThrust = clamp_f(baseThrust+THRUST_STEP, THRUST_MIN, THRUST_MAX);
            Serial.print("[FC] thrust+ "); Serial.println(baseThrust,3); break;
        case 11:
            baseThrust = clamp_f(baseThrust-THRUST_STEP, THRUST_MIN, THRUST_MAX);
            Serial.print("[FC] thrust- "); Serial.println(baseThrust,3); break;
        case 12: motorsArmed = true;  Serial.println("[FC] ARMED");   break;
        case 13:
            motorsArmed = false; motorsSetAll(1000);
            Serial.println("[FC] DISARMED"); break;
        case 0xFF: Serial.println("[FC] PONG"); break;
        default: Serial.printf("[FC] unknown cmd %d\n", cmd); break;
    }
}

static void handleCommand(const Command &c) {
    char buf[sizeof(c.cmd)+1];
    memcpy(buf, c.cmd, sizeof(c.cmd));
    buf[sizeof(c.cmd)] = '\0';
    if ((uint8_t)buf[0] < 32) applyCommand((uint8_t)buf[0]);
    else {
        uint8_t mapped = stringToCmd(buf);
        if (mapped) applyCommand(mapped);
        else { Serial.print("[FC] unknown: "); Serial.println(buf); }
    }
}

// ===================== Telemetry =====================
static uint32_t nextTelemMs = 0;
static int32_t  telemNum    = 0;

static void sendTelemetry() {
    SensorData sd;
    sd.pressure = tLib.baro.readPressure();
    sd.num      = telemNum++;
    strncpy(sd.state, motorsArmed ? "ARMED" : "DISARMED", sizeof(sd.state)-1);
    sd.state[sizeof(sd.state)-1] = '\0';
    sd.roll = rollEst; sd.pitch = pitchEst; sd.yaw = yawEst;
    sd.thrust = baseThrust;
    sd.lipo_v = tLib.vlipo.readVoltage();
    sd.m1=m1_us; sd.m2=m2_us; sd.m3=m3_us; sd.m4=m4_us;
    sendPacket(Serial1, sd);
    Serial.printf("[FC] P=%.1f arm=%d thr=%.2f r=%.1f p=%.1f y=%.1f v=%.2f m=%d/%d/%d/%d\n",
        sd.pressure,(int)motorsArmed,baseThrust,rollEst,pitchEst,yawEst,sd.lipo_v,
        m1_us,m2_us,m3_us,m4_us);
}

// ===================== Setup / Loop =====================
void setup() {
    Wire.begin();
    Serial.begin(115200);
    Serial1.begin(921600, SERIAL_8N1);
    Serial.println("[FC] Boot");

    int s = tLib.init();
    if (s != 1) { Serial.print("[FC] tLib init failed: "); Serial.println(s); while(true){} }

    tLib.led.off();
    motorsSetAll(1000);

    // Serial.println("[FC] Calibrating accel...");
    // calibrateAccel();
    Serial.println("[FC] Calibrating gyro...");
    calibrateGyro();
    Serial.println("[FC] Done.");

    lastImuUs   = micros();
    nextTelemMs = millis() + TELEMETRY_PERIOD_MS;
    delay(200);
    sendPIDConfig();
}

void loop() {
    const uint32_t nowMs = millis();
    const uint32_t nowUs = micros();

    tLib.update();
    sensorStep(nowUs);

    // Single dispatcher — handles Command and PIDCommand frofam the same stream
    {
        Command    cmd;
        PIDCommand pc;
        uint8_t type;
        while ((type = receiveAnyPacket(Serial1, nullptr, &cmd, &pc, nullptr)) != 0) {
            if (type == PKT_COMMAND) {
                bool wasArmed = motorsArmed;
                handleCommand(cmd);
                if (wasArmed && !motorsArmed) resetPIDState();
            } else if (type == PKT_PID_COMMAND) {
                applyPIDCommand(pc);
            }
        }
    }

    // Low voltage cutoff
    if (tLib.vlipo.readVoltage() < 6.0f) {
        if (motorsArmed) resetPIDState();
        motorsArmed = false; baseThrust = 0.0f; motorsSetAll(1000);
    }

    static uint32_t lastRateUs  = 0;
    static uint32_t lastAngleUs = 0;

    if (!lastRateUs)  lastRateUs  = nowUs;
    if (!lastAngleUs) lastAngleUs = nowUs;

    // Angle loop — 250 Hz
    if ((int32_t)(nowUs - lastAngleUs) >= (int32_t)ANGLE_PERIOD_US) {
        lastAngleUs += ANGLE_PERIOD_US;

        float angleErr_roll  = rollEst;
        float angleErr_pitch = pitchEst;

        angleI_roll  = clamp_f(angleI_roll  + angleErr_roll  * ANGLE_DT, -ANGLE_I_MAX, ANGLE_I_MAX);
        angleI_pitch = clamp_f(angleI_pitch + angleErr_pitch * ANGLE_DT, -ANGLE_I_MAX, ANGLE_I_MAX);

        rollSp  = clamp_f(ANGLE_KP_ROLL  * angleErr_roll  + ANGLE_KI_ROLL  * angleI_roll,
                          -MAX_ANGLE_RATE_DPS, MAX_ANGLE_RATE_DPS);
        pitchSp = clamp_f(ANGLE_KP_PITCH * angleErr_pitch + ANGLE_KI_PITCH * angleI_pitch,
                          -MAX_ANGLE_RATE_DPS, MAX_ANGLE_RATE_DPS);
    }

    // Rate loop — 1000 Hz
    if ((int32_t)(nowUs - lastRateUs) >= (int32_t)RATE_PERIOD_US) {
        lastRateUs += RATE_PERIOD_US;

        static float gx_f=0, gy_f=0, gz_f=0;
        gx_f += GYRO_LPF_ALPHA*(gx_dps-gx_f);
        gy_f += GYRO_LPF_ALPHA*(gy_dps-gy_f);
        gz_f += GYRO_LPF_ALPHA*(gz_dps-gz_f);

        float rollRate  = ROLL_RATE_SIGN  * gx_f;
        float pitchRate = PITCH_RATE_SIGN * gy_f;
        float yawRate   = YAW_RATE_SIGN   * gz_f;

        float rateErr_roll  = rollSp  - rollRate;
        float rateErr_pitch = pitchSp - pitchRate;
        float rateErr_yaw   = 0.0f    - yawRate;

        rateI_roll  = clamp_f(rateI_roll  + rateErr_roll  * RATE_DT, -RATE_I_MAX, RATE_I_MAX);
        rateI_pitch = clamp_f(rateI_pitch + rateErr_pitch * RATE_DT, -RATE_I_MAX, RATE_I_MAX);
        rateI_yaw   = clamp_f(rateI_yaw   + rateErr_yaw   * RATE_DT, -RATE_I_MAX, RATE_I_MAX);

        float rateD_roll  = -(rollRate  - rollRate_prev)  / RATE_DT;
        float rateD_pitch = -(pitchRate - pitchRate_prev) / RATE_DT;
        float rateD_yaw   = -(yawRate   - yawRate_prev)   / RATE_DT;
        rollRate_prev  = rollRate;
        pitchRate_prev = pitchRate;
        yawRate_prev   = yawRate;

        float rollOut  = clamp_f(RATE_KP_ROLL  * rateErr_roll  + RATE_KI_ROLL  * rateI_roll  + RATE_KD_ROLL  * rateD_roll,  -ROLL_OUT_MAX,  ROLL_OUT_MAX);
        float pitchOut = clamp_f(RATE_KP_PITCH * rateErr_pitch + RATE_KI_PITCH * rateI_pitch + RATE_KD_PITCH * rateD_pitch, -PITCH_OUT_MAX, PITCH_OUT_MAX);
        float yawOut   = clamp_f(RATE_KP_YAW   * rateErr_yaw   + RATE_KI_YAW   * rateI_yaw   + RATE_KD_YAW   * rateD_yaw,  -YAW_OUT_MAX,   YAW_OUT_MAX);

        float m1 = baseThrust + rollOut  + yawOut;
        float m2 = baseThrust + pitchOut - yawOut;
        float m3 = baseThrust - rollOut  + yawOut;
        float m4 = baseThrust - pitchOut - yawOut;

        m1_us = constrain((int)(m1*1000+1000), 1000, 2000);
        m2_us = constrain((int)(m2*1000+1000), 1000, 2000);
        m3_us = constrain((int)(m3*1000+1000), 1000, 2000);
        m4_us = constrain((int)(m4*1000+1000), 1000, 2000);

        if (!motorsArmed) motorsSetAll(1000);
        else {
            tLib.motors.set(1,m1_us); tLib.motors.set(2,m2_us);
            tLib.motors.set(3,m3_us); tLib.motors.set(4,m4_us);
        }
    }

    if ((int32_t)(nowMs - nextTelemMs) >= 0) {
        sendTelemetry();
        nextTelemMs += TELEMETRY_PERIOD_MS;
    }
}
