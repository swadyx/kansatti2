// ===================== FC <-> BRIDGE UART =====================
// Set this to the Teensy UART actually wired to the bridge.
// I am defaulting to Serial1 because that was used in your original FC sketch.
static HardwareSerial &BRIDGE_SERIAL = Serial1;
static constexpr uint32_t BRIDGE_BAUD = 921600;

// ===================== STATE =====================
static Proto::Parser bridgeParser;
static uint16_t txSeq = 1;

static bool armed = false;
static uint8_t currentState = Proto::STATE_IDLE;
static uint16_t statusFlags = 0;
static uint32_t lastStatusMs = 0;
static bool lastGpsFix = false;
static uint32_t lastPrimaryMissionMs = 0;
static uint32_t lastAttitudeMs = 0;


static uint16_t nextSeq() {
  return txSeq++;
}

static bool gpsHasFixNow() {
  return tLib.gps.fixType() > 0;
}

static uint16_t readLipoMv() {
  const float v = tLib.vlipo.readVoltage();
  if (v <= 0.0f) return 0;
  float mv = v * 1000.0f;
  if (mv < 0.0f) mv = 0.0f;
  if (mv > 65535.0f) mv = 65535.0f;
  return (uint16_t)(mv + 0.5f);
}



static bool stateImpliesArmed(uint8_t s) {
  return !(s == Proto::STATE_IDLE || s == Proto::STATE_GROUND || s == Proto::STATE_FAULT);
}

static void updateStatusFlags() {
  if (gpsHasFixNow()) statusFlags |= Proto::STATUSF_GPS_FIX;
  else                statusFlags &= (uint16_t)~Proto::STATUSF_GPS_FIX;
}

static void sendPrimaryMission() {
  Proto::PrimaryMissionPayload p{};
  p.pressure_pa = (int32_t)(tLib.baro.readPressure() + (tLib.baro.readPressure() >= 0 ? 0.5f : -0.5f));
  p.temperature_cC = (int32_t)(tLib.thermistor.readCelsius() * 100.0f + (tLib.thermistor.readCelsius() >= 0 ? 0.5f : -0.5f));
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_PRIMARY_MISSION, 0, nextSeq(), p);
}

static void sendAttitude() {
  float ax, ay, az, gx, gy, gz;
  tLib.imu.readAccel(ax, ay, az);
  tLib.imu.readGyro(gx, gy, gz);

  const float roll_deg = atan2f(ay, az) * 57.2957795f;
  const float pitch_deg = atan2f(-ax, sqrtf(ay * ay + az * az)) * 57.2957795f;
  const float yaw_deg = 0.0f;

  Proto::AttitudePayload a{};
  a.roll_cdeg = (int16_t)(roll_deg * 100.0f);
  a.pitch_cdeg = (int16_t)(pitch_deg * 100.0f);
  a.yaw_cdeg = (int16_t)(yaw_deg * 100.0f);
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_ATTITUDE, 0, nextSeq(), a);
}

static void sendAck(uint16_t ackedSeq, uint8_t status, uint8_t detail = 0) {
  Proto::AckPayload ack{};
  ack.acked_seq = ackedSeq;
  ack.status = status;
  ack.detail = detail;
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_ACK, Proto::FLAG_IS_RESPONSE, nextSeq(), ack);
}

static void sendInfo(uint8_t code, int32_t value) {
  Proto::InfoPayload p{};
  p.source = Proto::SRC_FC;
  p.code = code;
  p.value = value;
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_INFO, 0, nextSeq(), p);
}

static void sendError(uint8_t code, int32_t value) {
  Proto::ErrorPayload p{};
  p.source = Proto::SRC_FC;
  p.code = code;
  p.value = value;
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_ERROR, Proto::FLAG_IMPORTANT, nextSeq(), p);
}

static void sendEvent(uint8_t eventId, int32_t value = 0) {
  Proto::EventPayload p{};
  p.event_id = eventId;
  p.source = Proto::SRC_FC;
  p.value = value;
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_EVENT, Proto::FLAG_IMPORTANT, nextSeq(), p);
}

static void sendStatus() {
  updateStatusFlags();
  Proto::StatusPayload s{};
  s.state = currentState;
  s.armed = armed ? 1 : 0;
  s.gps_fix = gpsHasFixNow() ? 1 : 0;
  s.lipo_mV = readLipoMv();
  s.flags = statusFlags;

  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_STATUS, 0, nextSeq(), s);

  DBG_PRINTF("[FC] STATUS state=%s armed=%u gps=%u lipo=%.3fV flags=0x%04X\n",
             Proto::stateName(s.state),
             (unsigned)s.armed,
             (unsigned)s.gps_fix,
             s.lipo_mV / 1000.0f,
             s.flags);
}

static void setState(uint8_t newState) {
  if (currentState == newState) return;
  currentState = newState;
  setArmed(stateImpliesArmed(newState));
  sendStatus();
}

static void setArmed(bool newArmed) {
  if (armed == newArmed) return;
  armed = newArmed;
  if (!armed) {
    tLib.motors.set(1, 1000);
    tLib.motors.set(2, 1000);
    tLib.motors.set(3, 1000);
    tLib.motors.set(4, 1000);
  }
  sendStatus();
}

static void sendOneShotIMU() {
  float ax, ay, az;
  float gx, gy, gz;
  tLib.imu.readAccel(ax, ay, az);
  tLib.imu.readGyro(gx, gy, gz);

  Proto::ImuRawPayload p{};
  p.ax_g   = ax;
  p.ay_g   = ay;
  p.az_g   = az;
  p.gx_dps = gx;
  p.gy_dps = gy;
  p.gz_dps = gz;

  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_IMU_RAW, 0, txSeq++, p);
}

static void sendOneShotBaro() {
  const float pressure = tLib.baro.readPressure();
  sendInfo(Proto::INFO_TEST_BARO, (int32_t)(pressure + (pressure >= 0 ? 0.5f : -0.5f)));
}

static void sendOneShotThermistor() {
  const float tempC = tLib.thermistor.readCelsius();
  sendInfo(Proto::INFO_TEST_THERMISTOR, (int32_t)(tempC * 100.0f + (tempC >= 0 ? 0.5f : -0.5f)));
}

static void sendOneShotLdr() {
  const float ldrV = tLib.ldr.readVoltage();
  sendInfo(Proto::INFO_TEST_LDR, (int32_t)(ldrV * 1000.0f + (ldrV >= 0 ? 0.5f : -0.5f)));
}

static void sendOneShotGps() {
  Proto::GpsPayload g{};
  g.lat_e7 = (int32_t)(tLib.gps.latitude() * 10000000.0);
  g.lon_e7 = (int32_t)(tLib.gps.longitude() * 10000000.0);
  g.alt_cm = (int32_t)(tLib.gps.altitude() * 100.0f + (tLib.gps.altitude() >= 0 ? 0.5f : -0.5f));
  g.sats = 0;
  g.fix_type = (uint8_t)tLib.gps.fixType();
  g.ground_speed_cms = 0;
  Proto::sendTyped(BRIDGE_SERIAL, Proto::MSG_GPS, 0, nextSeq(), g);
}

static bool handleCommand(const Proto::Packet &pkt) {
  Proto::CommandPayload cmd{};
  if (!Proto::payloadAs(pkt, cmd)) {
    sendAck(pkt.header.seq, Proto::ACK_BAD_LENGTH);
    return false;
  }

  if (!(cmd.dest == Proto::DEST_FC || cmd.dest == Proto::DEST_ALL)) {
    sendAck(pkt.header.seq, Proto::ACK_BAD_DEST);
    return false;
  }

  DBG_PRINTF("[FC] CMD seq=%u cmd=%s arg0=%ld arg1=%ld\n",
             pkt.header.seq,
             Proto::commandName(cmd.cmd_id),
             (long)cmd.arg0,
             (long)cmd.arg1);

  switch (cmd.cmd_id) {
    case Proto::CMD_PING:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendInfo(Proto::INFO_PING_REPLY, 1);
      return true;

    case Proto::CMD_STATUS_REQUEST:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendStatus();
      return true;

    case Proto::CMD_SET_STATE:
      if (cmd.arg0 < Proto::STATE_IDLE || cmd.arg0 > Proto::STATE_FAULT) {
        sendAck(pkt.header.seq, Proto::ACK_REJECTED, 1);
        return false;
      }
      setState((uint8_t)cmd.arg0);
      sendAck(pkt.header.seq, Proto::ACK_OK);
      return true;

    case Proto::CMD_TEST_BARO:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendOneShotBaro();
      return true;

    case Proto::CMD_TEST_IMU:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendOneShotIMU();
      return true;

    case Proto::CMD_TEST_THERMISTOR:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendOneShotThermistor();
      return true;

    case Proto::CMD_TEST_LDR:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendOneShotLdr();
      return true;

    case Proto::CMD_TEST_GPS:
      sendAck(pkt.header.seq, Proto::ACK_OK);
      sendOneShotGps();
      return true;

    default:
      sendAck(pkt.header.seq, Proto::ACK_UNKNOWN_CMD);
      return false;
  }
}

static void checkGpsEvents() {
  const bool nowFix = gpsHasFixNow();
  if (nowFix != lastGpsFix) {
    lastGpsFix = nowFix;
    sendEvent(nowFix ? Proto::EVT_GPS_FIX_ACQUIRED : Proto::EVT_GPS_FIX_LOST, tLib.gps.fixType());
  }
}

void setup() {
  Wire.begin();
  DBG_BEGIN(115200);
  BRIDGE_SERIAL.begin(BRIDGE_BAUD, SERIAL_8N1);

  DBG_PRINTLN("[FC] boot");

  const int status = tLib.init();
  if (status != 1) {
    statusFlags |= Proto::STATUSF_INIT_FAILED;
    DBG_PRINT("[FC] Tonttulib init failed with code: ");
    DBG_PRINTLN(status);
    sendError(1, status);
    while (true) {
      delay(1000);
    }
  }

  tLib.led.blinkFast();

  // Keep motors at minimum while testing comms.
  tLib.motors.set(1, 1000);
  tLib.motors.set(2, 1000);
  tLib.motors.set(3, 1000);
  tLib.motors.set(4, 1000);

  uint32_t lastAddr = 0;
  uint8_t gen = 0, seq = 0;
  if (tLib.eeprom.readLatestFlashAddress(lastAddr, gen, seq)) {
    statusFlags |= Proto::STATUSF_FLASH_PRESENT;
    DBG_PRINTF("[FC] Recovered flash addr=0x%08lX gen=%u seq=%u\n",
               (unsigned long)lastAddr, (unsigned)gen, (unsigned)seq);
    sendInfo(Proto::INFO_FLASH_ADDR, (int32_t)lastAddr);
  } else {
    DBG_PRINTLN("[FC] No valid flash log found");
    sendInfo(Proto::INFO_FLASH_NOT_FOUND, 0);
  }

  delay(100);
  setArmed(stateImpliesArmed(currentState));
  sendEvent(Proto::EVT_BOOT, 0);
  sendInfo(Proto::INFO_FC_BOOT, 0);
  lastGpsFix = gpsHasFixNow();
  sendStatus();
}

void loop() {
  tLib.update();

  if (tLib.gps.hasNewData()) {
    DBG_PRINTF("[FC] GPS fix=%d lat=%.7f lon=%.7f alt=%.2f\n",
               tLib.gps.fixType(),
               tLib.gps.latitude(),
               tLib.gps.longitude(),
               tLib.gps.altitude());
    tLib.gps.clearNewData();
  }

  checkGpsEvents();

  Proto::Packet pkt{};
  while (Proto::readPacket(BRIDGE_SERIAL, bridgeParser, pkt)) {
    if (pkt.header.type == Proto::MSG_COMMAND) {
      handleCommand(pkt);
    } else {
      DBG_PRINTF("[FC] Ignored type=%s seq=%u len=%u\n",
                 Proto::messageTypeName(pkt.header.type),
                 pkt.header.seq,
                 pkt.header.payload_len);
    }
  }

  const uint32_t nowMs = millis();
  if ((uint32_t)(nowMs - lastStatusMs) >= 1000U) {
    lastStatusMs = nowMs;
    sendStatus();

    #if FC_DEBUG
    const float temp = tLib.thermistor.readCelsius();
    const float ldrV = tLib.ldr.readVoltage();
    const float pressure = tLib.baro.readPressure();
    const float lipoV = tLib.vlipo.readVoltage();
    DBG_PRINTF("[FC] temp=%.2fC ldr=%.2fV pressure=%.1fPa lipo=%.3fV\n",
               temp, ldrV, pressure, lipoV);
    #endif
  }

  // if ((uint32_t)(nowMs - lastPrimaryMissionMs) >= 200U) {
  //   lastPrimaryMissionMs = nowMs;
  //   sendPrimaryMission();
  // }

  // if ((uint32_t)(nowMs - lastAttitudeMs) >= 200U) {
  //   lastAttitudeMs = nowMs;
