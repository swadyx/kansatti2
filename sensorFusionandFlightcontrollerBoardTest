int16_t temp;

// ================= ACCEL BIAS ===============
double accelBiasX=0, accelBiasY=0, accelBiasZ=0;
void calibrateAccel() {
  double sumAx=0, sumAy=0, sumAz=0;
  const int samples = 3000;
  for(int i=0; i<samples; i++){
    bmi088.getAcceleration(&ax, &ay, &az);
    ax *= MG_TO_G; ay *= MG_TO_G; az *= MG_TO_G;
    sumAx += ax;
    sumAy += ay;
    sumAz += az;
    delayMicroseconds(500);
  }
  accelBiasX = sumAx / samples;
  accelBiasY = sumAy / samples;
  accelBiasZ = sumAz / samples + 1.0;
}

// ================= GYRO BIAS ===============
double gyroBiasX=0, gyroBiasY=0, gyroBiasZ=0;
void calibrateGyro(){
  const int samples = 3000;
  for(int i=0;i<samples;i++){
    bmi088.getGyroscope(&gx,&gy,&gz);
    float alphaA = 0.2;
    ogx += alphaA * (gx-ogx);
    gx=ogx;
    ogy += alphaA * (gy-ogy);
    gy=ogy;
    ogz += alphaA * (gz-ogz);
    gz=ogz;
    gyroBiasX +=gx;
    gyroBiasY +=gy;
    gyroBiasZ +=gz;
    delayMicroseconds(500);
  }
  gyroBiasX /= samples;
  gyroBiasY /= samples;
  gyroBiasZ /= samples;
  ogx = 0;
  ogy = 0;
  ogz = 0;
}

// ================= EKF STATE =================
double q0=1, q1=0, q2=0, q3=0;
double P0=3, P1=3, P2=3;
double accelNoise=0.1;
double gyroNoise=0.001;
float alphaGyro=1;
double lastGPSLat=0;
double lastGPSLon=0;
double currentYaw=0;
double thrust=0.45;
double rollIntegral=0, pitchIntegral=0, yawIntegral=0;
double rollLastErr=0, pitchLastErr=0, yawLastErr=0;
double motor1_pwm, motor2_pwm, motor3_pwm, motor4_pwm;

