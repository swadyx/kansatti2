#include <Wire.h>
#include "BMI088.h"
#include <avr/pgmspace.h>

#define GPS_BYTE_TIMEOUT_MS 250
BMI088 bmi088(BMI088_ACC_ADDRESS, BMI088_GYRO_ADDRESS);

constexpr float MG_TO_G = 1.0f / 1000.0f;

unsigned long imuIntervalMs = 20;
unsigned long lastImuTime = 0;
double alphaAngle = 0.1;
// ================= FILTER =================
double rollFiltered = 0;
double pitchFiltered = 0;
double yawFiltered = 0;
// ================= IMU =================
float ax, ay, az;
float gx, gy, gz;
int16_t temp;
// ================= GYRO BIAS ===============
double gyroBiasX=0, gyroBiasY=0, gyroBiasZ=0;
void calibrateGyro(){
  const int samples = 1000;
  for(int i=0;i<samples;i++){
    bmi088.getGyroscope(&gx,&gy,&gz);
    gyroBiasX += gx;
    gyroBiasY += gy;
    gyroBiasZ += gz;
    delay(2);
  }
  gyroBiasX /= samples;
  gyroBiasY /= samples;
  gyroBiasZ /= samples;
}

// ================= EKF STATE =================
double q0=1, q1=0, q2=0, q3=0;
double P0=3, P1=3, P2=3;
double accelNoise=0.2;
double gyroNoise=0.001;

double lastGPSLat=0;
double lastGPSLon=0;
double currentYaw=0;

double thrust=0.45;

double rollIntegral=0, pitchIntegral=0, yawIntegral=0;
double rollLastErr=0, pitchLastErr=0, yawLastErr=0;

double motor1_pwm, motor2_pwm, motor3_pwm, motor4_pwm;

// ================= GPS STRUCT (required for parsing) =================
struct NAV_PVT {
  unsigned char cls;
  unsigned char id;
  unsigned short len;
  unsigned long iTOW;
  unsigned short year;
  unsigned char month;
  unsigned char day;
  unsigned char hour;
  unsigned char minute;
  unsigned char second;
  char valid;
  unsigned long tAcc;
  long nano;
  unsigned char fixType;
  char flags;
  unsigned char reserved1;
  unsigned char numSV;
  long lon;
  long lat;
  long height;
  long hMSL;
  unsigned long hAcc;
  unsigned long vAcc;
  long velN;
  long velE;
  long velD;
  long gSpeed;
  long heading;
  unsigned long sAcc;
  unsigned long headingAcc;
  unsigned short pDOP;
  short reserved2;
  unsigned long reserved3;
};

NAV_PVT pvt;

const unsigned char UBX_HEADER[] = {0xB5,0x62};

// ================= Utility =================
void normalizeQuaternion() {
  double n = sqrt(q0*q0 + q1*q1 + q2*q2 + q3*q3);
  if(n < 1e-9){ q0=1; q1=q2=q3=0; return; }
  q0/=n; q1/=n; q2/=n; q3/=n;
}

void quaternionMultiply(double w,double x,double y,double z){
  double nw=q0*w - q1*x - q2*y - q3*z;
  double nx=q0*x + q1*w + q2*z - q3*y;
  double ny=q0*y - q1*z + q2*w + q3*x;
  double nz=q0*z + q1*y - q2*x + q3*w;
  q0=nw; q1=nx; q2=ny; q3=nz;
}

double pidUpdate(double input,double setpoint,
                 double kp,double ki,double kd,
                 double &integral,double &lastErr){
  double dt=0.02;
  double err=setpoint-input;
  integral+=err*dt;
  integral=constrain(integral,-0.3,0.3);
  double derivative=(err-lastErr)/dt;
  lastErr=err;
  return kp*err + ki*integral + kd*derivative;
}

// ================= EKF =================
void ekfPredict(double gx,double gy,double gz,double dt){
  double dq0=0.5*(-q1*gx - q2*gy - q3*gz);
  double dq1=0.5*( q0*gx + q2*gz - q3*gy);
  double dq2=0.5*( q0*gy - q1*gz + q3*gx);
  double dq3=0.5*( q0*gz + q1*gy - q2*gx);

  q0+=dq0*dt; q1+=dq1*dt; q2+=dq2*dt; q3+=dq3*dt;
  normalizeQuaternion();

  double qNoise=gyroNoise*dt*dt;
  P0+=qNoise; P1+=qNoise; P2+=qNoise;
}

void ekfUpdateAccel(double ax,double ay,double az){
  double norm=sqrt(ax*ax+ay*ay+az*az);
  if(norm<1e-6)return;
  ax/=norm; ay/=norm; az/=norm;

  double hx=2*(q1*q3 - q0*q2);
  double hy=2*(q0*q1 + q2*q3);
  double hz=q0*q0 - q1*q1 - q2*q2 + q3*q3;

  double y0=ax-hx;
  double y1=ay-hy;
  double y2=az-hz;

  double K0=P0/(P0+accelNoise);
  double K1=P1/(P1+accelNoise);
  double K2=P2/(P2+accelNoise);

  double dX=K0*y0;
  double dY=K1*y1;
  double dZ=K2*y2;

  double theta=sqrt(dX*dX+dY*dY+dZ*dZ);

  double dq_w,dq_x,dq_y,dq_z;

  if(theta<1e-6){
    dq_w=1; dq_x=0.5*dX; dq_y=0.5*dY; dq_z=0.5*dZ;
  }else{
    double halfTheta=theta*0.5;
    double sinHalf=sin(halfTheta)/theta;
    dq_w=cos(halfTheta);
    dq_x=dX*sinHalf;
    dq_y=dY*sinHalf;
    dq_z=dZ*sinHalf;
  }

  quaternionMultiply(dq_w,dq_x,dq_y,dq_z);
  normalizeQuaternion();

  P0*=(1.0-K0);
  P1*=(1.0-K1);
  P2*=(1.0-K2);
}

// ================= GPS =================
void calcChecksum(unsigned char* CK){
  memset(CK,0,2);
  for(int i=0;i<(int)sizeof(NAV_PVT);i++){
    CK[0]+=((unsigned char*)(&pvt))[i];
    CK[1]+=CK[0];
  }
}

bool processGPS(){
  static int fpos=0;
  static unsigned char checksum[2];
  static uint32_t lastByteTime=0;

  while(Serial2.available()){
    byte c=Serial2.read();
    uint32_t now=millis();

    if(lastByteTime!=0 && (now-lastByteTime)>GPS_BYTE_TIMEOUT_MS)
      fpos=0;
    lastByteTime=now;

    if(fpos<2){
      if(c==UBX_HEADER[fpos]) fpos++;
      else fpos=0;
    }else{
      if((fpos-2)<sizeof(NAV_PVT))
        ((unsigned char*)(&pvt))[fpos-2]=c;

      fpos++;

      if(fpos==(sizeof(NAV_PVT)+2))
        calcChecksum(checksum);
      else if(fpos==(sizeof(NAV_PVT)+3)){
        if(c!=checksum[0]) fpos=0;
      }
      else if(fpos==(sizeof(NAV_PVT)+4)){
        fpos=0;
        if(c==checksum[1]) return true;
      }
    }
  }
  return false;
}

// ================= SETUP =================
void setup(){
  Wire.begin();
  Serial.begin(115200);
  Serial2.begin(9600);

  while(!bmi088.isConnection()) delay(500);
  bmi088.initialize();

  bmi088.setGyroPoweMode(GYRO_NORMAL);
  bmi088.setGyroScaleRange(RANGE_500);
  bmi088.setGyroOutputDataRate(ODR_200_BW_23);

  bmi088.setAccPoweMode(ACC_ACTIVE);
  bmi088.setAccScaleRange(RANGE_6G);
  bmi088.setAccOutputDataRate(ODR_200);

  calibrateGyro();
}

// ================= LOOP =================
void loop(){

  if(processGPS()){
    double lat=pvt.lat/10000000.0;
    double lon=pvt.lon/10000000.0;

    double dx=(lat-lastGPSLat)*111320.0;
    double dy=(lon-lastGPSLon)*111320.0*cos(lat*DEG_TO_RAD);

    lastGPSLat=lat;
    lastGPSLon=lon;

    if(dx!=0 || dy!=0){
      double gpsYaw=atan2(dy,dx);
      currentYaw += 0.1*(gpsYaw-currentYaw);

      double yawError=gpsYaw-currentYaw;
      quaternionMultiply(cos(0.5*yawError),0,0,sin(0.5*yawError));
      normalizeQuaternion();
    }
  }

  unsigned long now=millis();
  if(now-lastImuTime>=imuIntervalMs){

    double dt=0.02;
    lastImuTime=now;

    bmi088.getAcceleration(&ax,&ay,&az);
    bmi088.getGyroscope(&gx,&gy,&gz);

    gx -= gyroBiasX;
    gy -= gyroBiasY;
    gz -= gyroBiasZ;


    ax*=MG_TO_G; ay*=MG_TO_G; az*=MG_TO_G;

    ekfPredict(gx*DEG_TO_RAD,
               gy*DEG_TO_RAD,
               gz*DEG_TO_RAD,
               dt);

    ekfUpdateAccel(ax,ay,az);

    double roll=atan2(2*(q0*q1+q2*q3),
                      1-2*(q1*q1+q2*q2));

    double pitch=asin(2*(q0*q2-q3*q1));

    double yaw=atan2(2*(q0*q3+q1*q2),
                     1-2*(q2*q2+q3*q3));

    rollFiltered += alphaAngle * (roll-rollFiltered);
    pitchFiltered += alphaAngle * (pitch-pitchFiltered);
    yawFiltered += alphaAngle * (yaw-yawFiltered);

    roll = rollFiltered;
    pitch = pitchFiltered;
    yaw = yawFiltered;

    double rollOut=pidUpdate(roll,0,
                             0.05,0.002,0.001,
                             rollIntegral,rollLastErr);

    double pitchOut=pidUpdate(pitch,0,
                              0.05,0.002,0.001,
                              pitchIntegral,pitchLastErr);

    double yawOut=pidUpdate(yaw,0,
                            0.05,0.002,0.001,
                            yawIntegral,yawLastErr);

    rollOut=constrain(rollOut,-0.3,0.3);
    pitchOut=constrain(pitchOut,-0.3,0.3);
    yawOut=constrain(yawOut,-0.2,0.2);

    double m1=thrust-rollOut+pitchOut+yawOut;
    double m2=thrust+rollOut-pitchOut+yawOut;
    double m3=thrust+rollOut+pitchOut-yawOut;
    double m4=thrust-rollOut-pitchOut-yawOut;

    motor1_pwm=constrain(m1*1000+1000,1000,2000);
    motor2_pwm=constrain(m2*1000+1000,1000,2000);
    motor3_pwm=constrain(m3*1000+1000,1000,2000);
    motor4_pwm=constrain(m4*1000+1000,1000,2000);

    Serial.print("Roll: ");Serial.print(roll);
    Serial.print(" Pitch: ");Serial.print(pitch);
    Serial.print(" Yaw: ");Serial.println(yaw);

    Serial.print("Motors: ");
    Serial.print(motor1_pwm);Serial.print(" ");
    Serial.print(motor2_pwm);Serial.print(" ");
    Serial.print(motor3_pwm);Serial.print(" ");
    Serial.println(motor4_pwm);
  }
}
