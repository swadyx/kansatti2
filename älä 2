// --- calibration (accel in g, gyro in dps) ---
static void calibrateAccel() {
  double sumAx=0, sumAy=0, sumAz=0;
  const int samples = 3000;
  for(int i=0; i<samples; i++){
    tLib.imu.readAccel(ax, ay, az); // g
    sumAx += ax; sumAy += ay; sumAz += az;
    delayMicroseconds(500);
  }
  accelBiasX = sumAx / samples;
  accelBiasY = sumAy / samples;
  accelBiasZ = (sumAz / samples) - 1.0; // assumes "rest" ~ +1g on Z
}

static void calibrateGyro() {
  gyroBiasX = gyroBiasY = gyroBiasZ = 0;
  ogx = ogy = ogz = 0;

  const int samples = 3000;
  for (int i=0;i<samples;i++){
    tLib.imu.readGyro(gx, gy, gz); // dps
    const float alphaA = 0.2f;
    ogx += alphaA * (gx - ogx); gx = ogx;
    ogy += alphaA * (gy - ogy); gy = ogy;
    ogz += alphaA * (gz - ogz); gz = ogz;

    gyroBiasX += gx;
    gyroBiasY += gy;
    gyroBiasZ += gz;
    delayMicroseconds(500);
  }
  gyroBiasX /= samples;
  gyroBiasY /= samples;
  gyroBiasZ /= samples;

  ogx = ogy = ogz = 0;
}

// ===================== EKF-ish quaternion fusion (from your 2nd code) =====================
// Notes:
// - Predict uses gyro rad/s
// - Update uses accel (unit vector), only corrects roll/pitch (yaw unobservable)
// - We keep yaw damping using gyro rate in the controller to stay stable

static double q0=1, q1=0, q2=0, q3=0;      // w,x,y,z
static double P0=3, P1=3, P2=3;            // simple diagonal covariance proxy
static double accelNoise=0.1;
static double gyroNoise=0.1;

// output smoothing for angles (radians)
static double alphaAngle = 1;
static double rollFiltered_rad = 0;
static double pitchFiltered_rad = 0;
static double yawFiltered_rad = 0;

static inline void normalizeQuaternion() {
  double n = sqrt(q0*q0 + q1*q1 + q2*q2 + q3*q3);
  if (n < 1e-9) { q0=1; q1=q2=q3=0; return; }
  q0/=n; q1/=n; q2/=n; q3/=n;
}

// applies q = q * dq (right-multiply by small correction quaternion)
static inline void quaternionMultiply(double w,double x,double y,double z){
  double nw=q0*w - q1*x - q2*y - q3*z;
  double nx=q0*x + q1*w + q2*z - q3*y;
  double ny=q0*y - q1*z + q2*w + q3*x;
  double nz=q0*z + q1*y - q2*x + q3*w;
  q0=nw; q1=nx; q2=ny; q3=nz;
}

static inline void ekfPredict(double gx_rs,double gy_rs,double gz_rs,double dt){
  // quaternion derivative using body rates
  double dq0=0.5*(-q1*gx_rs - q2*gy_rs - q3*gz_rs);
  double dq1=0.5*( q0*gx_rs + q2*gz_rs - q3*gy_rs);
  double dq2=0.5*( q0*gy_rs - q1*gz_rs + q3*gx_rs);
  double dq3=0.5*( q0*gz_rs + q1*gy_rs - q2*gx_rs);

  q0+=dq0*dt; q1+=dq1*dt; q2+=dq2*dt; q3+=dq3*dt;
  normalizeQuaternion();

  // crude covariance growth
  double qNoiseRoll  = gyroNoise * gyroNoise * dt;
  double qNoisePitch = qNoiseRoll;
  double qNoiseYaw   = qNoiseRoll * 4.0;

  P0 += qNoiseRoll;
  P1 += qNoisePitch;
  P2 += qNoiseYaw;
}

static inline void ekfUpdateAccel(double ax_u, double ay_u, double az_u){
  double norm = sqrt(ax_u*ax_u + ay_u*ay_u + az_u*az_u);
  if (norm < 1e-6) return;

  // reject strong linear acceleration
  if (fabs(norm - 1.0) > 0.2) return;

  ax_u/=norm; ay_u/=norm; az_u/=norm;

  // expected gravity direction from quaternion
  double hx = 2 * (q1 * q3 + q0 * q2);
  double hy = 2 * (q2 * q3 - q0 * q1);
  double hz = (q0*q0 - q1*q1 - q2*q2 + q3*q3);

  double y0 = ax_u - hx;
  double y1 = ay_u - hy;
  double y2 = az_u - hz;

  // gains for roll/pitch; yaw not observable from accel -> keep K2=0
  double K0 = P0 / (P0 + accelNoise);
  double K1 = P1 / (P1 + accelNoise);
  double K2 = 0.0;

  // small-angle correction vector (tuned to your original)
  double dX = K0 * y1;
  double dY = K1 * (-y0);
  double dZ = K2 * y2;

  double theta = sqrt(dX*dX + dY*dY + dZ*dZ);
  double dq_w,dq_x,dq_y,dq_z;

  if (theta < 1e-6) {
    dq_w=1; dq_x=0.5*dX; dq_y=0.5*dY; dq_z=0.5*dZ;
  } else {
    double halfTheta = theta * 0.5;
    double sinHalf = sin(halfTheta) / theta;
    dq_w = cos(halfTheta);
    dq_x = dX * sinHalf;
    dq_y = dY * sinHalf;
    dq_z = dZ * sinHalf;
  }

  quaternionMultiply(dq_w,dq_x,dq_y,dq_z);
  normalizeQuaternion();

  P0 *= (1.0 - K0);
  P1 *= (1.0 - K1);
  P2 *= (1.0 - K2);
}

// angle unwrap helper for yaw control if you ever want it
static inline double wrapPi(double a){
  while (a >  3.14159265358979323846) a -= 2.0*3.14159265358979323846;
  while (a < -3.14159265358979323846) a += 2.0*3.14159265358979323846;
  return a;
}

// ===================== SENSOR STEP (EKF fusion) =====================
static void sensorStep(uint32_t nowUs){
  if ((int32_t)(nowUs - lastImuUs) < (int32_t)IMU_PERIOD_US) return;

  const uint32_t prevUs = lastImuUs;
  lastImuUs = nowUs;

  float dt = (nowUs - prevUs) * 1e-6f;
  if (dt <= 0.0f || dt > 0.05f) dt = (float)(IMU_PERIOD_US * 1e-6f);

  // read sensors
  tLib.imu.readAccel(ax, ay, az); // g

  tLib.imu.readGyro(gx, gy, gz);  // dps

  // accel bias corrected (g) for EKF update & telemetry
  ax_g = ax - (float)accelBiasX;
  ay_g = ay - (float)accelBiasY;
  az_g = az - (float)accelBiasZ;

  // adaptive gyro bias update when stable (helps a lot)
  float gyroMag = sqrtf(gx*gx + gy*gy + gz*gz);
  if(gyroMag < 0.5f && fabsf(ax_g) < 0.15f && fabsf(ay_g) < 0.15f && fabsf(az_g - 1.0f) < 0.20f){
    const float biasAlpha = 0.03f;
    gyroBiasX += biasAlpha * ((double)gx - gyroBiasX);
    gyroBiasY += biasAlpha * ((double)gy - gyroBiasY);
    gyroBiasZ += biasAlpha * ((double)gz - gyroBiasZ);
  }

  // bias-corrected gyro rates (dps) for controller + EKF predict
  gx_dps = gx - (float)gyroBiasX;
  gy_dps = gy - (float)gyroBiasY;
  gz_dps = gz - (float)gyroBiasZ;

  // rotate IMU frame → EKF body frame
// Raw from IMU: ax=left(+), ay=forward(+), az=down(+)
// Bias-corrected: ax_g, ay_g, az_g

  // Remap to standard: X=forward, Y=right, Z=down
  // FIXED remapping for YOUR IMU (X+ = left, Y+ = forward, Z+ = down)
  // EKF body frame now matches your mixer: X = forward, Y = right, Z = down
  double ax_ekf =  ay_g;          // forward accel → X body (forward)
  double ay_ekf = -ax_g;          // left accel  → negative right
  double az_ekf =  az_g;          // down remains down (gravity +1g at level)

  double gx_ekf =  gy_dps * DEG_TO_RAD;   // forward rate → X gyro
  double gy_ekf = -gx_dps * DEG_TO_RAD;   // left rate  → negative right rate
  double gz_ekf =  gz_dps * DEG_TO_RAD;

  ekfPredict(gx_ekf, gy_ekf, gz_ekf, (double)dt);
  ekfUpdateAccel(ax_ekf, ay_ekf, az_ekf);

  // quaternion -> Euler (radians)
  double roll  = atan2( q1*q0 + q2*q3 , 0.5 - q1*q1 - q2*q2 );
  double pitch = -1*asin ( 2.0 * (q0*q2 - q3*q1) );
  double yaw   = atan2( q1*q2 + q0*q3 , 0.5 - q2*q2 - q3*q3 );

  // smooth angles a bit
  rollFiltered_rad  += alphaAngle * (roll  - rollFiltered_rad);
  pitchFiltered_rad += alphaAngle * (pitch - pitchFiltered_rad);
  yawFiltered_rad   += alphaAngle * (yaw   - yawFiltered_rad);

  // export for telemetry in degrees
  roll_deg  = (float)(rollFiltered_rad  * RAD_TO_DEG);
  pitch_deg = (float)(pitchFiltered_rad * RAD_TO_DEG);
  yaw_deg   = (float)(yawFiltered_rad   * RAD_TO_DEG);
}

// ===================== Telemetry packet (32 bytes) =====================
static uint8_t telemSeq = 0;
static uint32_t nextTelemMs = 0;

static void buildTelemetry(uint8_t* p /*32 bytes*/) {
  auto put_i16 = [&](int idx, int16_t v) {
    p[idx + 0] = (uint8_t)(v & 0xFF);
    p[idx + 1] = (uint8_t)((v >> 8) & 0xFF);
  };
  auto put_u16 = [&](int idx, uint16_t v) {
    p[idx + 0] = (uint8_t)(v & 0xFF);
    p[idx + 1] = (uint8_t)((v >> 8) & 0xFF);
  };

  p[0] = 'T';
  p[1] = telemSeq++;

  int16_t ax_mg = clamp_i16((int32_t)lroundf(ax_g * 1000.0f));
  int16_t ay_mg = clamp_i16((int32_t)lroundf(ay_g * 1000.0f));
  int16_t az_mg = clamp_i16((int32_t)lroundf(az_g * 1000.0f));

  int16_t gx_cdps = clamp_i16((int32_t)lroundf(gx_dps * 100.0f));
  int16_t gy_cdps = clamp_i16((int32_t)lroundf(gy_dps * 100.0f));
  int16_t gz_cdps = clamp_i16((int32_t)lroundf(gz_dps * 100.0f));

  // angles from EKF (deg)
  int16_t roll_cdeg  = clamp_i16((int32_t)lroundf(roll_deg  * 100.0f));
  int16_t pitch_cdeg = clamp_i16((int32_t)lroundf(pitch_deg * 100.0f));
  int16_t yaw_cdeg   = clamp_i16((int32_t)lroundf(yaw_deg   * 100.0f));

  uint16_t lipo_mV = (uint16_t)(tLib.vlipo.readVoltage() * 1000.0f);
  uint16_t thrust_permille = clamp_u16((int32_t)lroundf(baseThrust * 1000.0f));

  put_i16( 2, ax_mg);
  put_i16( 4, ay_mg);
  put_i16( 6, az_mg);
  put_i16( 8, gx_cdps);
  put_i16(10, gy_cdps);
  put_i16(12, gz_cdps);
  put_i16(14, roll_cdeg);
  put_i16(16, pitch_cdeg);
  put_i16(18, yaw_cdeg);
  put_u16(20, lipo_mV);
  put_u16(22, thrust_permille);

  // commanded motor PWM (us)
  put_u16(24, m1_cmd_us);
  put_u16(26, m2_cmd_us);
  put_u16(28, m3_cmd_us);
  put_u16(30, m4_cmd_us);
}

// ===================== Commands (NO ACKS) =====================
static void applyCommand(uint8_t cmd) {
  switch (cmd) {
    case 1: tLib.led.on();        Serial.println("[AIR] LED on"); break;
    case 2: tLib.led.off();       Serial.println("[AIR] LED off"); break;
    case 3: tLib.led.blinkFast(); Serial.println("[AIR] LED blinkFast"); break;
    case 4: tLib.led.blinkSlow(); Serial.println("[AIR] LED blinkSlow"); break;

    case 10:
      baseThrust = clamp_f(baseThrust + THRUST_STEP, THRUST_MIN, THRUST_MAX);
      Serial.print("[AIR] baseThrust up -> "); Serial.println(baseThrust, 3);
      break;

    case 11:
      baseThrust = clamp_f(baseThrust - THRUST_STEP, THRUST_MIN, THRUST_MAX);
      Serial.print("[AIR] baseThrust down -> "); Serial.println(baseThrust, 3);
      break;

    case 12: // fly (arm)
      motorsArmed = true;
      Serial.println("[AIR] MOTORS ARMED (fly)");
      break;

    case 13: // stop (kill + disarm)
      motorsArmed = false;
      motorsSetAll(1000);
      Serial.println("[AIR] MOTORS DISARMED + STOP");
      break;

    default:
      Serial.println("[AIR] unknown cmd");
      break;
  }
}

static void handleCommandPacket(const uint8_t* p, size_t n) {
  if (n < 3) return;
  if (p[0] != 'C') return;

  const uint8_t seq = p[1];
  const uint8_t cmd = p[2];

  Serial.print("[AIR] RX C seq="); Serial.print(seq);
  Serial.print(" cmd="); Serial.println(cmd);

  applyCommand(cmd);

  (void)seq;
}

// ===================== UART line handler =====================
static void handleRadioLine(const char* l) {
  if (LOG_RAW_MODEM_LINES) {
    Serial.print("[AIR][RAW] ");
    Serial.println(l);
  }

  if (strstr(l, "+MODE: TEST"))  { modeIsTest = true; modeIsLWABP = false; }
  if (strstr(l, "+MODE: LWABP")) { modeIsLWABP = true; modeIsTest = false; }

  if (strstr(l, "TX") && strstr(l, "DONE")) {
    sawTxDone = true;
  }

  char hexPayload[200];
  size_t hexLen = 0;
  if (extractRxHex(l, hexPayload, sizeof(hexPayload), hexLen)) {
    uint8_t pkt[64]; size_t pktLen = 0;
    if (!hexToBytes(hexPayload, hexLen, pkt, sizeof(pkt), pktLen)) return;
    handleCommandPacket(pkt, pktLen);
  }
}

static void pollRadioUart() {
  while (Serial1.available()) {
    char c = (char)Serial1.read();
    if (c == '\r') continue;
    if (c == '\n') {
      lineBuf[lineLen] = 0;
      handleRadioLine(lineBuf);
      lineLen = 0;
    } else {
      if (lineLen + 1 < sizeof(lineBuf)) lineBuf[lineLen++] = c;
      else lineLen = 0;
    }
  }
}

// ===================== Link step (NO ACKS) =====================
static void linkStep(uint32_t nowMs) {
  // periodic mode check
  static uint32_t nextModeCheck = 0;
  if ((int32_t)(nowMs - nextModeCheck) >= 0) {
    sendCmd("AT+MODE=?");
    nextModeCheck = nowMs + MODE_RECHECK_MS;
    if (modeIsLWABP) {
      startRecovery(nowMs);
      setLinkState(LS_IDLE);
      return;
    }
  }

  switch (linkState) {
    case LS_IDLE:
      if ((int32_t)(nowMs - nextTelemMs) >= 0) {
        setLinkState(LS_TX_TELEM);
      }
      break;

    case LS_TX_TELEM: {
      uint8_t p[32];
      buildTelemetry(p);
      radioTx(p, sizeof(p));
      setLinkState(LS_WAIT_TXDONE);
      break;
    }

    case LS_WAIT_TXDONE:
      if (sawTxDone || (int32_t)(nowMs - txStartMs) >= (int32_t)TX_DONE_TIMEOUT_MS) {
        sawTxDone = false;
        armRxNow(); // always keep RX armed after any TX
        nextTelemMs = nowMs + TELEMETRY_PERIOD_MS;
        setLinkState(LS_IDLE);
      }
      break;
  }
}

// ===================== Angle PID (roll/pitch) + yaw rate damping =====================
static double rollIntegral=0, pitchIntegral=0;
static double rollLastErr=0, pitchLastErr=0;

// PID helper
static inline double pidUpdate(double input, double setpoint,
                               double kp, double ki, double kd,
                               double &integral, double &lastErr,
                               double dt){
  double err = setpoint - input;
  integral += err * dt;
  integral = constrain(integral, -0.3, 0.3);
  double derivative = (err - lastErr) / (dt > 1e-6 ? dt : 1e-6);
  lastErr = err;
  return kp*err + ki*integral + kd*derivative;
}

// ===================== Setup / loop =====================
void setup() {
  Wire.begin();
  Serial.begin(115200);
  Serial1.begin(9600);

  logLine("Boot");

  int status = tLib.init();
  if (status != 1) {
    Serial.print("[AIR] Tonttulib init failed code: ");
    Serial.println(status);
    while (true) {}
  }

  tLib.led.off();

  // safe motors
  motorsSetAll(1000);

  Serial.println("[AIR] Calibrating accel...");
  calibrateAccel();
  Serial.println("[AIR] Calibrating gyro...");
  calibrateGyro();
  Serial.println("[AIR] Calibration done.");

  // EKF init
  q0=1; q1=q2=q3=0;
  P0=P1=P2=3;
  rollFiltered_rad = pitchFiltered_rad = yawFiltered_rad = 0;

  initState = I_IDLE;
  initT0 = millis();

  lastImuUs = micros();
  nextTelemMs = millis() + TELEMETRY_PERIOD_MS;
  setLinkState(LS_IDLE);
}
double m1,m2,m3,m4;
static inline void getTiltError(double &errRoll, double &errPitch)
{
  // gravity vector from quaternion (in body frame X=forward, Y=right, Z=down)
  double gx = 2.0 * (q1*q3 + q0*q2);   // gravity forward (nose-down tilt)
  double gy = 2.0 * (q2*q3 - q0*q1);   // gravity right   (right-down tilt)

  // Signs matched to your 4 tilt pictures + motor PWM changes:
  // Tilt nose down (m2) → front motors must drop, back must rise
  // Tilt right down (m1) → right motor (m1) must rise, left (m3) must drop
  errRoll  =  -gy;   // positive = gravity right → roll left (lift right)
  errPitch =  gx;   // positive = gravity forward → pitch up (lift back)
}

void loop() {
  const uint32_t nowMs = millis();
  const uint32_t nowUs = micros();

  tLib.update();
  sensorStep(nowUs);

  // ================= Low Voltage Cutoff =================
  float lipoV = tLib.vlipo.readVoltage();
  if (lipoV < 6.0f) {
    motorsArmed = false;
    baseThrust = 0.0f;
    motorsSetAll(1000);
    return;
  }

  // ================= PID dt =================
  static uint32_t lastPidUs = 0;
  if (lastPidUs == 0) lastPidUs = nowUs;

  double dtPid = (nowUs - lastPidUs) * 1e-6;
  lastPidUs = nowUs;
  if (dtPid <= 0.0 || dtPid > 0.1) dtPid = 0.005;

  // ================= Gyro Filtering (for yaw damping) =================
  static float gx_f = 0, gy_f = 0, gz_f = 0;
  const float alpha = 0.25f;
  gx_f += alpha * (gx_dps - gx_f);
  gy_f += alpha * (gy_dps - gy_f);
  gz_f += alpha * (gz_dps - gz_f);

  // ================= Axis Mapping =================
  // +Y front
  // +X right
  // +Z up
  //

  const double yawRate_dps = (double)gz_f;

  // EKF angles are in global roll_deg/pitch_deg/yaw_deg (degrees)


// ================= TILT CONTROL (NO EULERS) =================

double errRoll, errPitch;
getTiltError(errRoll, errPitch);

// PID gains in "tilt units" (not degrees)
const double KP_TILT = 0.07;
const double KI_TILT = 0.0;
const double KD_TILT = 0.008;

// derivative using gyro (physically correct damping)
double rollRate  = gx_f * DEG_TO_RAD;
double pitchRate = gy_f * DEG_TO_RAD;

rollIntegral  += errRoll  * dtPid;
pitchIntegral += errPitch * dtPid;

rollIntegral  = constrain(rollIntegral,  -0.3, 0.3);
pitchIntegral = constrain(pitchIntegral, -0.3, 0.3);

double rollOut =
    KP_TILT * errRoll
  + KI_TILT * rollIntegral
  - KD_TILT * rollRate;

double pitchOut =
    KP_TILT * errPitch
  + KI_TILT * pitchIntegral
  - KD_TILT * pitchRate;

  // ================= Yaw: simple rate damping  =================
  const double KP_YAW_RATE = 0.0008;
  double yawOut = KP_YAW_RATE * (0.0 - yawRate_dps);

  // Clamp outputs (keep your previous safe clamps)
  rollOut  = constrain(rollOut, -0.25, 0.25);
  pitchOut = constrain(pitchOut, -0.25, 0.25);
  yawOut   = constrain(yawOut,   -0.12, 0.12);

  // ================= PLUS FRAME MIXER =================
  //
  // m1 = +X (right)   CW
  // m2 = +Y (front)   CCW
  // m3 = -X (left)    CW
  // m4 = -Y (back)    CCW

  static double rollOutFilt=0, pitchOutFilt=0;
  rollOutFilt  += 0.1 * (rollOut  - rollOutFilt);
  pitchOutFilt += 0.1 * (pitchOut - pitchOutFilt);
double temp_roll  = pitchOutFilt;     // original pitch command becomes new roll
  double temp_pitch = -rollOutFilt;      // original roll command becomes new pitch

  // Now apply INVERTED signs so thrust increases on the low side
  m1 = baseThrust + temp_roll  + yawOut;   // right   ↑ when right needs lift
  m2 = baseThrust + temp_pitch - yawOut;   // front   ↑ when front needs lift
  m3 = baseThrust - temp_roll  + yawOut;   // left    ↑ when left needs lift
  m4 = baseThrust - temp_pitch - yawOut;   // back    ↑ when back needs lift

  // ================= PWM Mapping =================
  m1_cmd_us = (uint16_t)constrain((int)(m1 * 1000.0 + 1000.0), 1000, 2000);
  m2_cmd_us = (uint16_t)constrain((int)(m2 * 1000.0 + 1000.0), 1000, 2000);
  m3_cmd_us = (uint16_t)constrain((int)(m3 * 1000.0 + 1000.0), 1000, 2000);
  m4_cmd_us = (uint16_t)constrain((int)(m4 * 1000.0 + 1000.0), 1000, 2000);

  // ================= Motor Output =================
  if (!motorsArmed) {
    motorsSetAll(1000);
  } else {
    tLib.motors.set(1, m1_cmd_us);
    tLib.motors.set(2, m2_cmd_us);
    tLib.motors.set(3, m3_cmd_us);
    tLib.motors.set(4, m4_cmd_us);
  }

  // ================= Radio + Link =================
  pollRadioUart();

  if (initState != I_READY) {
    initStep(nowMs);
    return;
  }

  linkStep(nowMs);
}
