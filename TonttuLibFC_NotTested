const float GYRO_STABLE_THRESH_DPS = 15.0;     
const float ACCEL_NEAR_G_MIN = 0.85;
const float ACCEL_NEAR_G_MAX = 1.15;
// ================= FILTER =================
double rollFiltered = 0;
double pitchFiltered = 0;
